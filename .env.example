# Copy to .env locally. Never commit real secrets.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

SHORTS_PIPELINE_PROJECT_ROOT=projects
SHORTS_PIPELINE_DB_PATH=projects/shorts_pipeline.sqlite3
SHORTS_PIPELINE_KDENLIVE_MIN_VERSION=26.04.1

# Optional real LLM adapters. Disabled by default; the deterministic fake
# providers are used unless BOTH variables below are set. No real API call is
# ever made by tests or CI.
# SHORTS_PIPELINE_ENABLE_REAL_LLM=1
# SHORTS_PIPELINE_LLM_BACKEND=openai  # one of: openai, anthropic, gemini
